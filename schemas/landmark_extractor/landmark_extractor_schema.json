{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://gesturelabs.org/schemas/landmark_extractor_schema.json",
  "title": "Landmark Extractor Schema",
  "description": "Schema for landmark_extractor input and output messages.",
  "type": "object",
  "$defs": {
    "LandmarkVector": {
      "$defs": {
        "LandmarkPoint": {
          "properties": {
            "x": {
              "title": "X",
              "type": "number"
            },
            "y": {
              "title": "Y",
              "type": "number"
            },
            "z": {
              "title": "Z",
              "type": "number"
            },
            "visibility": {
              "title": "Visibility",
              "type": "number"
            }
          },
          "required": [
            "x",
            "y",
            "z",
            "visibility"
          ],
          "title": "LandmarkPoint",
          "type": "object"
        }
      },
      "properties": {
        "pose_landmarks": {
          "additionalProperties": {
            "$ref": "#/$defs/LandmarkPoint"
          },
          "title": "Pose Landmarks",
          "type": "object"
        },
        "left_hand_landmarks": {
          "additionalProperties": {
            "$ref": "#/$defs/LandmarkPoint"
          },
          "title": "Left Hand Landmarks",
          "type": "object"
        },
        "right_hand_landmarks": {
          "additionalProperties": {
            "$ref": "#/$defs/LandmarkPoint"
          },
          "title": "Right Hand Landmarks",
          "type": "object"
        },
        "face_landmarks": {
          "additionalProperties": {
            "$ref": "#/$defs/LandmarkPoint"
          },
          "title": "Face Landmarks",
          "type": "object"
        }
      },
      "title": "LandmarkVector",
      "type": "object"
    }
  }
}
