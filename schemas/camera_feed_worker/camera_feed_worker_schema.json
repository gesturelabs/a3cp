{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://gesturelabs.org/schemas/camera_feed_worker_schema.json",
  "title": "Camera Feed Worker Schema",
  "description": "Schema for camera_feed_worker input and output messages.",
  "type": "object",
  "$defs": {
    "CameraFeedWorkerOutput": {
      "description": "Canonical JSON control-message output for camera_feed_worker (Sprint 1 minimal).\n\nOnly abort messages are defined at schema level.\nSuccess-path behavior is transport-defined (e.g., close without error) and/or\nexpressed via service actions, not via JSON output schemas.",
      "properties": {
        "schema_version": {
          "description": "Semantic version (MAJOR.MINOR.PATCH)",
          "title": "Schema Version",
          "type": "string"
        },
        "record_id": {
          "description": "Unique ID for this message (UUIDv4)",
          "format": "uuid",
          "title": "Record Id",
          "type": "string"
        },
        "user_id": {
          "description": "Pseudonymous user identifier",
          "title": "User Id",
          "type": "string"
        },
        "session_id": {
          "anyOf": [
            {
              "description": "Session ID from session_manager",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Session Id"
        },
        "timestamp": {
          "description": "UTC ISO 8601 with milliseconds and 'Z' suffix",
          "format": "date-time",
          "title": "Timestamp",
          "type": "string"
        },
        "modality": {
          "anyOf": [
            {
              "description": "Input/message modality",
              "enum": [
                "gesture",
                "audio",
                "speech",
                "image",
                "multimodal"
              ],
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Modality"
        },
        "source": {
          "anyOf": [
            {
              "description": "Originating component (e.g., 'gesture_classifier')",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Source"
        },
        "performer_id": {
          "anyOf": [
            {
              "description": "Actor producing input; 'system' for system-generated",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Performer Id"
        },
        "event": {
          "const": "capture.abort",
          "description": "Control message type emitted by camera_feed_worker",
          "title": "Event",
          "type": "string"
        },
        "capture_id": {
          "description": "Capture ID associated with this response",
          "title": "Capture Id",
          "type": "string"
        },
        "error_code": {
          "description": "Stable error_code for abort events",
          "title": "Error Code",
          "type": "string"
        }
      },
      "required": [
        "schema_version",
        "record_id",
        "user_id",
        "timestamp",
        "event",
        "capture_id",
        "error_code"
      ],
      "title": "CameraFeedWorkerOutput",
      "type": "object"
    }
  }
}
